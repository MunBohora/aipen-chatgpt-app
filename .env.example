# Aipen render source
AIPEN_RENDER_BASE=http://localhost:3000
PORT=3001

# Required in production. Never infer this from forwarded request headers.
PUBLIC_BASE_URL=https://api.example.com

# Anonymous demo protection
MAX_ANONYMOUS_RENDERS_PER_HOUR=40

# Private Google Cloud Storage artifact bucket. Cloud Run authenticates using
# its service account; no key values belong in this file.
GCS_ARTIFACT_BUCKET=aipen-mcp-artifacts
